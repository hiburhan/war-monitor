{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "NASA_FIRMS_API_KEY": "@nasa_firms_api_key",
    "OPENSKY_USERNAME": "@opensky_username",
    "OPENSKY_PASSWORD": "@opensky_password"
  }
}
